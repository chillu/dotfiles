{{ if eq .machineType "work" -}}
# Runn CLI completions (must be before oh-my-zsh)
fpath=(~/.zsh/completions $fpath)
{{ end -}}

# If you come from bash you might have to change your $PATH.
export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH
export PATH=$HOME/.opencode/bin:$PATH

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

# Which plugins would you like to load?
plugins=(git docker brew macos extract copypath colored-man-pages z)

source $ZSH/oh-my-zsh.sh

# Aliases
alias dc='docker compose'
alias cc='claude'
alias tailscale='/Applications/Tailscale.app/Contents/MacOS/Tailscale'
alias subl="'/Applications/Sublime Text.app/Contents/SharedSupport/bin/subl'"
alias lzg='lazygit'
alias lzd='lazydocker'
alias oc='opencode'

# Load NVM for interactive shells
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"

# 1Password CLI plugins
if [ -f ~/.config/op/plugins.sh ]; then
  source ~/.config/op/plugins.sh
fi

# wt (worktrunk) shell integration
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

{{ if eq .machineType "work" -}}
# Heroku autocomplete
HEROKU_AC_ZSH_SETUP_PATH=~/Library/Caches/heroku/autocomplete/zsh_setup
if [ -f "$HEROKU_AC_ZSH_SETUP_PATH" ]; then
  source "$HEROKU_AC_ZSH_SETUP_PATH"
fi
{{ end -}}

# Local overrides — brew, installers, and manual tweaks go here
# This file is NOT managed by chezmoi, so it won't be overwritten
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
