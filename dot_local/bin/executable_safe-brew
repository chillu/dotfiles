#!/bin/bash
# safe-brew: Hardened Homebrew installer with minimum age check
# Usage: safe-brew install <package>
#        safe-brew info <package>
#        safe-brew check <package>
#
# Checks if a Homebrew formula is at least MIN_AGE_DAYS old before installing.
# Uses the GitHub API to check when the formula was last modified in homebrew-core.
# This provides a cooling-off period to catch supply chain compromises.

set -euo pipefail

MIN_AGE_DAYS=7
HOMEBREW_CORE_API="https://api.github.com/repos/homebrew/homebrew-core/commits"

usage() {
    echo "Usage: safe-brew [install|info|check] <package>"
    echo ""
    echo "  install  - Install package if formula is >= $MIN_AGE_DAYS days old"
    echo "  info     - Show package info + age"
    echo "  check    - Check formula age without installing"
    echo ""
    echo "Environment:"
    echo "  SAFE_BREW_MIN_AGE  - Override minimum age (default: $MIN_AGE_DAYS)"
    echo "  SAFE_BREW_FORCE    - Set to 'yes' to bypass age check"
    exit 1
}

check_formula_age() {
    local package="$1"
    local formula_path

    # Map package to formula path (handle single-letter dirs)
    local first_char="${package:0:1}"
    if [[ "$first_char" =~ [a-z] ]]; then
        formula_path="Formula/${first_char}/${package}.rb"
    else
        formula_path="Formula/${package}.rb"
    fi

    # Check if this is a cask
    local is_cask=false
    if brew info --cask "$package" &>/dev/null; then
        is_cask=true
        formula_path="Casks/${package}.rb"
    fi

    local api_url="${HOMEBREW_CORE_API}?path=${formula_path}&per_page=1"

    # Fetch last commit date from GitHub API
    local response
    if ! response=$(curl -fsSL -H "Accept: application/vnd.github.v3+json" "$api_url" 2>/dev/null); then
        echo "⚠️  Could not reach GitHub API. Formula age unknown."
        return 1
    fi

    local commit_date
    commit_date=$(echo "$response" | python3 -c "import sys, json; print(json.load(sys.stdin)[0]['commit']['committer']['date'])" 2>/dev/null)

    if [[ -z "$commit_date" ]]; then
        echo "⚠️  Could not parse commit date. Formula age unknown."
        return 1
    fi

    local commit_ts
    commit_ts=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$commit_date" "+%s" 2>/dev/null || date -d "$commit_date" "+%s")

    local now_ts
    now_ts=$(date "+%s")

    local age_days=$(( (now_ts - commit_ts) / 86400 ))

    echo "$age_days"
}

cmd_check() {
    local package="$1"
    echo "🔍 Checking formula age for: $package"
    echo ""

    local age_days
    if ! age_days=$(check_formula_age "$package"); then
        echo ""
        echo "❌ Cannot verify formula age. Use 'safe-brew install --force' or set SAFE_BREW_FORCE=yes to bypass."
        return 1
    fi

    echo "Formula age: $age_days days"
    echo "Minimum required: ${SAFE_BREW_MIN_AGE:-$MIN_AGE_DAYS} days"
    echo ""

    if [[ "$age_days" -lt "${SAFE_BREW_MIN_AGE:-$MIN_AGE_DAYS}" ]]; then
        echo "⚠️  Formula is TOO NEW ($age_days days < ${SAFE_BREW_MIN_AGE:-$MIN_AGE_DAYS} days)"
        echo "   This formula was recently modified. Waiting reduces supply chain risk."
        echo ""
        echo "Options:"
        echo "  1. Wait and install later"
        echo "  2. Install from official GitHub release with checksum verification"
        echo "  3. Override: SAFE_BREW_FORCE=yes safe-brew install $package"
        return 1
    else
        echo "✅ Formula is old enough ($age_days days >= ${SAFE_BREW_MIN_AGE:-$MIN_AGE_DAYS} days)"
        return 0
    fi
}

cmd_info() {
    local package="$1"
    echo "📦 Package: $package"
    echo ""
    brew info "$package" 2>/dev/null || brew info --cask "$package" 2>/dev/null || echo "Package not found"
    echo ""
    cmd_check "$package" || true
}

cmd_install() {
    local package="$1"

    # Allow --force flag
    if [[ "${2:-}" == "--force" ]]; then
        SAFE_BREW_FORCE=yes
    fi

    echo "🛡️  safe-brew install: $package"
    echo ""

    # Check if already installed
    if brew list "$package" &>/dev/null; then
        echo "ℹ️  $package is already installed."
        echo "   To upgrade: brew upgrade $package (after checking age)"
        return 0
    fi

    # Bypass check if forced
    if [[ "${SAFE_BREW_FORCE:-}" == "yes" ]]; then
        echo "⚡ Force mode: skipping age check"
    else
        local age_days
        if ! age_days=$(check_formula_age "$package"); then
            echo ""
            echo "Cannot verify formula age. Override with: SAFE_BREW_FORCE=yes safe-brew install $package"
            return 1
        fi

        if [[ "$age_days" -lt "${SAFE_BREW_MIN_AGE:-$MIN_AGE_DAYS}" ]]; then
            echo "❌ Refusing to install $package"
            echo "   Formula is only $age_days days old (minimum: ${SAFE_BREW_MIN_AGE:-$MIN_AGE_DAYS} days)"
            echo ""
            echo "This protects against recently-introduced supply chain compromises."
            echo ""
            echo "Alternatives:"
            echo "  1. Wait a few days and retry"
            echo "  2. Download directly from the vendor's official release page"
            echo "  3. Override: SAFE_BREW_FORCE=yes safe-brew install $package"
            return 1
        fi

        echo "✅ Formula age check passed ($age_days days old)"
    fi

    echo ""
    echo "📋 Reviewing formula..."
    brew info "$package" 2>/dev/null || true
    echo ""
    read -r -p "Proceed with installation? [y/N] " response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        echo "Cancelled."
        return 1
    fi

    echo ""
    echo "📦 Installing $package..."
    brew install "$package"
    echo ""
    echo "✅ $package installed successfully"
}

# Main
case "${1:-}" in
    check)
        [[ -z "${2:-}" ]] && usage
        cmd_check "$2"
        ;;
    info)
        [[ -z "${2:-}" ]] && usage
        cmd_info "$2"
        ;;
    install)
        [[ -z "${2:-}" ]] && usage
        cmd_install "$2" "${3:-}"
        ;;
    *)
        usage
        ;;
esac
